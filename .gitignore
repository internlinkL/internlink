# ─────────────────────────────────────────────
#  .gitignore — internLink
#  Files that should NEVER be pushed to GitHub
# ─────────────────────────────────────────────

# Secret credentials — keep only on your machine
phpsecure/config.php
phpsecure/google_auth.php
phpsecure/mailer.php
# Uploaded files — too large for GitHub
student/uploads/
company/uploads/
uploads/

# Debug files
phpsecure/google_callback_debug.php
phpsecure/test.php

# XAMPP / system files
.DS_Store
Thumbs.db
*.log
